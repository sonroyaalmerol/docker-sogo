diff --git a/SoObjects/SOGo/SOGoWebAuthenticator.m b/SoObjects/SOGo/SOGoWebAuthenticator.m
index 84929f8d0..7f3093926 100644
--- a/SoObjects/SOGo/SOGoWebAuthenticator.m
+++ b/SoObjects/SOGo/SOGoWebAuthenticator.m
@@ -482,11 +482,18 @@
                            userKey, sessionKey];
   cookieValue = [NSString stringWithFormat: @"basic %@",
                           [cookieString stringByEncodingBase64]];
-  isSecure = [[[context serverURL] scheme] isEqualToString: @"https"];
+  // Honour X-Forwarded-Proto set by SSL-terminating reverse proxies so that
+  // the Secure flag is correct even when SOGo only sees plain HTTP internally.
+  NSString *forwardedProto = [[context request] headerForKey: @"x-forwarded-proto"];
+  if ([forwardedProto length])
+    isSecure = [[forwardedProto lowercaseString] isEqualToString: @"https"];
+  else
+    isSecure = [[[context serverURL] scheme] isEqualToString: @"https"];
+
   authCookie = [WOCookie cookieWithName: [self cookieNameInContext: context]
                                   value: cookieValue
                                    path: nil
-                                 domain: nil
+                                 domain: [[SOGoSystemDefaults sharedSystemDefaults] cookieDomain]
                                 expires: nil
                                isSecure: isSecure
                                httpOnly: YES];
