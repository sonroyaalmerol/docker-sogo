+
+      // For AJAX requests a cross-origin 302 to the OIDC provider is blocked
+      // by CORS. Return 401 instead so the Angular ErrorInterceptor can do a
+      // full-page reload, which triggers the OIDC redirect safely.
+      // We rely solely on X-Requested-With (set by AngularJS on every XHR)
+      // to avoid false-positives from k8s health probes that may also send
+      // Accept: application/json but must not receive a 401.
+      NSString *xRequestedWith = [rq headerForKey: @"x-requested-with"];
+      if ([xRequestedWith caseInsensitiveCompare: @"XMLHttpRequest"] == NSOrderedSame)
+        {
+          WOResponse *ajaxError = [WOResponse responseWithRequest: rq];
+          [ajaxError setStatus: 401];
+          [ajaxError setHeader: @"Bearer realm=\"SOGo\"" forKey: @"WWW-Authenticate"];
+          [ajaxError setHeader: @"application/json" forKey: @"content-type"];
+          [ajaxError appendContentString: @"{\"error\":\"session_expired\"}"];
+          return ajaxError;
+        }
+
